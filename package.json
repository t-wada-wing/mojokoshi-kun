{
  "name": "文字起こしくん",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --compatibility-date=2024-09-23 --d1=DB --r2=AUDIO --persist-to .wrangler/state",
    "db:init": "wrangler d1 execute transcribe-db --local --file=./schema.sql --persist-to .wrangler/state",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=mojiokoshi-kun",
    "ship:prod": "bash scripts/ship-prod.sh"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "fflate": "^0.8.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0",
    "wrangler": "^4.20.0"
  }
}
